# OpenWA Environment Variables for Render Deployment

# === CORE SETTINGS ===
NODE_ENV=production
PORT=2785
LOG_LEVEL=info

# === DATABASE (PostgreSQL) ===
DATABASE_TYPE=postgres
DATABASE_HOST=${DATABASE_URL_POSTGRES_HOST}
DATABASE_PORT=${DATABASE_URL_POSTGRES_PORT}
DATABASE_NAME=openwa
DATABASE_USERNAME=${DATABASE_URL_POSTGRES_USER}
DATABASE_PASSWORD=${DATABASE_URL_POSTGRES_PASSWORD}
DATABASE_SYNCHRONIZE=false

# === CACHE (Redis) ===
REDIS_HOST=${REDIS_URL_HOSTNAME}
REDIS_PORT=${REDIS_URL_PORT}
REDIS_PASSWORD=${REDIS_URL_PASSWORD}
REDIS_DB=0

# === ENGINE CONFIGURATION ===
ENGINE_TYPE=whatsapp-web.js
SESSION_DATA_PATH=/app/data/sessions
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu

# === STORAGE ===
STORAGE_TYPE=local
STORAGE_PATH=/app/data/media

# === API SECURITY ===
API_PORT=2785
OPENWA_ADMIN_API_KEY=owa_k1_change_me_to_a_long_random_secret
CORS_ORIGINS=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# === WEBHOOK SETTINGS (for production) ===
WEBHOOK_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# === DASHBOARD ===
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000

# === MONITORING ===
SENTRY_DSN=

# === PLUGINS ===
PLUGINS_ENABLED=true
PLUGINS_PATH=/app/data/plugins
